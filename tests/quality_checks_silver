-- ====================================================================
-- Checking: silver.crm_sales_details
-- ====================================================================

--checking unwanted spaces in order number
select *
from bronze.crm_sales_details
where sls_ord_num != trim(sls_ord_num);


--checking unwanted spaces in product key
select *
from bronze.crm_sales_details
where sls_prd_key != trim(sls_prd_key);


--checking foreign keys
select *
from bronze.crm_sales_details
where sls_prd_key not in (select prd_key from silver.crm_prd_info);

select *
from bronze.crm_sales_details
where sls_cust_id not in (select cst_id::text from silver.crm_cust_info);


--checking date issues
select sls_due_dt
from bronze.crm_sales_details
where sls_due_dt > 20300101
   or sls_due_dt < 19900101;

select sls_due_dt
from bronze.crm_sales_details
where sls_ship_dt < 0;


--checking invalid Order Dates
select *
from bronze.crm_sales_details
where sls_order_dt > sls_ship_dt
   or sls_order_dt > sls_due_dt;



--checking data consistency
--  sls_sales = sls_quantity * sls_price
select *
from bronze.crm_sales_details
where sls_sales <> sls_quantity * sls_price
   or sls_sales is null
   or sls_quantity is null
   or sls_price is null
   or sls_sales < 0;


--fix DDL
drop table if exists silver.crm_sales_details;
create table silver.crm_sales_details
(
    sls_ord_num TEXT,
    sls_prd_key   TEXT,
    sls_cust_id   INT,
    sls_order_dt  DATE,
    sls_ship_dt   DATE,
    sls_due_dt    DATE,
    sls_sales     INT,
    sls_quantity  INT,
    sls_price     INT,
    dwh_create_date date default current_date
);







