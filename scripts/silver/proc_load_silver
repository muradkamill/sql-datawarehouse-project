create or replace procedure silver.load_silver()
language plpgsql
    as $$
    declare number_of_row int;
        begin
        --silver.crm_cust_info loading
        insert into silver.crm_cust_info (cst_id, cst_key, cst_firstname, cst_lastname, cst_martial_status, cst_gndr, cst_create_date)
        select
            cst_id,
            cst_key,
            trim(cst_firstname) as cst_firstname,
            trim(cst_lastname) as  cst_lastname,
            case
                when upper(trim(cst_martial_status))='M' then 'Married'
                when upper(trim(cst_martial_status))='S' then 'Single'
                else 'n/a'
                end as cst_martial_status,
            case
                when upper(trim(cst_gndr))='F' then 'Female'
                when upper(trim(cst_gndr))='M' then 'Male'
                else 'n/a'
                end as cst_gndr,
            cst_create_date
        from (
                 select
                     *,
                     row_number() over (partition by cst_id order by cst_create_date desc) as flag_last
                 from bronze.crm_cust_info
                 where cst_id is not null
             ) t
        where flag_last=1;
        --silver.crm_prd_info loading
        insert into silver.crm_prd_info (prd_id, prd_key, cat_id, prd_nm, prd_cost, prd_line, prd_start_dt, prd_end_dt)
        select prd_id,
               substring(prd_key from 7 for length(prd_key))      as prd_key,
               replace(substring(prd_key from 1 for 5), '-', '_') as cat_id,
               prd_nm,
               coalesce(prd_cost, 0) as prd_cost,
               case
                   when upper(trim(prd_line)) = 'M' then 'Mountain'
                   when upper(trim(prd_line)) = 'R' then 'Road'
                   when upper(trim(prd_line)) = 'S' then 'Other Sales'
                   when upper(trim(prd_line)) = 'T' then 'Touring'
                   else 'n/a'
                   end as prd_line,
               prd_start_dt::date,
               lead(prd_start_dt) over(partition by prd_key order by prd_start_dt)::date -1 as prd_end_dt
        from (select *,
                     row_number() over (partition by prd_id order by prd_id) as rn
              from bronze.crm_prd_info
              where prd_id is not null) t
        where rn = 1;
        --silver.crm_sales_details loading
        insert into silver.crm_sales_details (sls_ord_num, sls_prd_key, sls_cust_id, sls_order_dt, sls_ship_dt, sls_due_dt, sls_sales, sls_quantity, sls_price)
        select sls_ord_num,
               sls_prd_key,
               sls_cust_id::int,
               case
                   when length(sls_order_dt::text) <> 8 or sls_order_dt < 0 then NULL
                   else sls_order_dt::text::date
                   end as sls_order_dt,
               sls_ship_dt::text::date as sls_ship_dt,
               sls_due_dt::text::date  as sls_due_dt,
               case
                   when sls_sales is null or sls_sales <0 or  sls_sales <> sls_quantity * abs(sls_price) then sls_quantity * abs(sls_price)
                   else sls_sales
                   end as sls_sales,
               sls_quantity,
               case
                   when sls_price<0 or sls_price is null   then   sls_sales/sls_quantity
                   else sls_price
                   end as sls_price
        from bronze.crm_sales_details;
        --silver.erp_cust_az12 loading
        insert into silver.erp_cust_az12 (cid, bdate, gen)
        select
            case
                when cid ilike 'NAS%' then substring(cid, 4,length(cid))
                else cid
                end as cid,
            case
                when  bdate::date > current_date then NULL
                else bdate::date
                end as bdate,
            case
                when trim(upper(gen)) in ('M','MALE') then 'Male'
                when trim(upper(gen)) in ('F','FEMALE') then 'Female'
                else 'n/a'
                end as gen
        from bronze.erp_cust_az12
        where cid in (select cst_key from silver.crm_cust_info);
        --silver.erp_loc_a101 loading
        insert into silver.erp_loc_a101 (cid, cntry)
        select
            replace(cid,'-','') as cid,
            case
                when trim(upper(cntry)) = 'DE' then 'Germany'
                when trim(upper(cntry)) in ('US','USA') then 'United States'
                when trim(cntry) = ''  or  trim(cntry) is null then 'n/a'
                else trim(cntry)
                end as cntry
        from bronze.erp_loc_a101
        where replace(cid,'-','') in (select cst_key from silver.crm_cust_info);
        --silver.erp_px_cat_g1v2 loading
        insert into silver.erp_px_cat_g1v2 (id, cat, subcat, maintenance)
        select
            id,
            cat as cat,
            subcat as sucat,
            maintenance as maintenance
        from bronze.erp_px_cat_g1v2
        where id in (select cat_id from silver.crm_prd_info);
        get diagnostics number_of_row=row_count;

        raise notice  '% row successfully loaded to silver layer',number_of_row;

        -- ratify transactions
        commit;

        exception
        when others then
        rollback;
        raise exception 'error happened : %',sqlerrm;
    end;
    $$
